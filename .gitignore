```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Django specific
*.sqlite3
*.log
local_settings.py

# Dependencies
venv/
.venv/
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
coverage/
htmlcov/

# Build artifacts
dist/
build/
*.egg-info/
```