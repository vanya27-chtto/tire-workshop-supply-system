```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
*.dist-info/

# Development environments
.venv/
venv/
.env
.env.local
*.env.*

# Logs
*.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Build and distribution artifacts
build/
dist/
*.egg
*.whl
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz

# Testing
.coverage
htmlcov/
.coverage.*
.pytest_cache/
.mypy_cache/
```